# Server
PORT=3000
NODE_ENV=development

# Database — two URLs required for Supabase + Prisma
# DATABASE_URL  → Session Pooler (used by the app at runtime)
# DIRECT_URL    → Direct connection (used only by prisma db push / migrate)
#
# Find both in: Supabase Dashboard → Settings → Database → Connection string
# Switch the dropdown to "Session mode" for DATABASE_URL (port 5432 on the pooler host)
# Use "Direct connection" for DIRECT_URL (port 5432 on db.[ref].supabase.co)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Token encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Internal API key for route protection (optional in dev)
INTERNAL_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback

# HighLevel OAuth (Marketplace app)
HL_CLIENT_ID=
HL_CLIENT_SECRET=
HL_REDIRECT_URI=http://localhost:3000/api/hl/callback

# Frontend
VITE_API_BASE_URL=http://localhost:3000
